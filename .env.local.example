# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git — it contains secrets.
# ─────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────
# Get these from: https://supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Twilio (WhatsApp notifications to owner) ─────────────────
# Get these from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token-here
# The Twilio sandbox WhatsApp number (or your approved sender)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# The owner's WhatsApp number that will receive reservation alerts
OWNER_WHATSAPP_NUMBER=whatsapp:+250792560660

# ── Site URL ──────────────────────────────────────────────────
# Vercel gives you a free URL automatically on first deploy (e.g. kawa-house.vercel.app)
# Paste that URL here. Change to your custom domain later when you buy one.
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
